# pixi environments
.pixi/*
!.pixi/config.toml

# Claude Code local overrides
CLAUDE.local.md
.claude/settings.local.json

# DuckDB skills state (created at runtime)
.duckdb-skills/

# Playwright skill node_modules (installed at runtime)
.claude/skills/playwright-skill/node_modules/
.claude/skills/playwright-skill/.temp-execution-*

# Project temp directory (cross-platform scratch space)
.tmp/

# Python bytecode
__pycache__/
*.pyc

# Data and Secrets
data/
.env
*.env
*.gitignore
*.gitattributes
