{
  "$schema": "https://json.schemastore.org/claude-code-settings.json",
  "permissions": {
    "allow": [
      "Bash(pixi *)",
      "Bash(pixi run *)",
      "Bash(duckdb *)",
      "Bash(node *)",
      "Bash(pnpm *)",
      "Bash(pnpx *)",
      "Bash(cd *)",
      "Bash(git status)",
      "Bash(git diff *)",
      "Bash(git log *)",
      "Bash(git branch *)",
      "Bash(ls *)",
      "Bash(dir *)",
      "Bash(mkdir *)",
      "Bash(test *)",
      "Bash(echo *)",
      "Bash(cat *)",
      "Bash(mv *)",
      "Bash(cp *)",
      "Bash(rm -f *)",
      "Bash(find *)",
      "Bash(grep *)",
      "Bash(curl *)",
      "Bash(command -v *)",
      "Bash(stat *)",
      "Bash(where *)",
      "Bash(pwsh *)",
      "Read",
      "Write",
      "Edit",
      "Glob",
      "Grep",
      "WebFetch(domain:pixi.prefix.dev)",
      "WebFetch(domain:duckdb.org)",
      "WebFetch(domain:gdal.org)",
      "WebFetch(domain:geoparquet.org)"
