{
  "$schema": "https://json-schemastore.org/claude-code-settings.json",
  "permissions": {
    "allow": [
      "Bash(pixi *)",
      "Bash(pixi run *)",
      "Bash(cd *)",
      "Bash(git status)",
      "Bash(git diff *)",
      "Bash(git log *)",
      "Bash(git branch *)",
      "Bash(ls *)",
      "Bash(dir *)",
      "Bash(mkdir *)",
      "Bash(test *)",
      "Bash(echo *)",
      "Bash(command -v *)",
      "Bash(stat *)",
      "Bash(wc *)",
      "Read",
      "Write",
      "Edit",
      "Glob",
      "Grep",
      "WebFetch(domain:pixi.prefix.dev)",
      "WebFetch(domain:duckdb.org)",
      "WebFetch(domain:gdal.org)",
      "WebFetch(domain:geoparquet.org)"
    ],
    "deny": [
      "Bash(rm -rf *)",
      "Bash(rm -r *)",
      "Bash(pixi clean *)",
      "Bash(npm *)",
      "Bash(npm install *)",
      "Bash(npx *)",
      "Read(**/.env)",
      "Read(**/.env.local)",
      "Read(**/.env.production)",
      "Read(**/.env.secret*)",
      "Bash(cat **/.env)",
      "Bash(cat **/.env.*)"
    ],
    "ask": [
      "Read(**/.env.dev)",
      "Read(.claude/skills/duckdb/references/*.sql)",
      "Grep(.claude/skills/duckdb/references/*.sql)",
      "Bash(curl *)",
      "Bash(s5cmd *)",
      "Bash(cp *)",
      "Bash(mv *)",
      "Bash(rm -f *)",
      "Bash(cat *)",
      "Bash(find *)",
      "Bash(grep *)"
    ]
  },
  "hooks": {
    "PreToolUse": [
      {
        "matcher": "Bash",
        "hooks": [
          {
            "type": "command",
            "command": "INPUT=$(cat); CMD=$(echo \"$INPUT\" | jq -r '.tool_input.command // empty'); case \"$CMD\" in npm\\ *|npm) echo 'BLOCKED: Use pixi run pnpm, not npm.' >&2; exit 2;; python\\ *|python3\\ *) case \"$CMD\" in *pixi*) exit 0;; *) echo 'BLOCKED: Use pixi run python, not python directly.' >&2; exit 2;; esac;; duckdb\\ *) case \"$CMD\" in *pixi*) exit 0;; *) echo 'BLOCKED: Use pixi run duckdb, not duckdb directly.' >&2; exit 2;; esac;; gdal\\ *|ogr2ogr\\ *|gdalinfo\\ *|ogrinfo\\ *) case \"$CMD\" in *pixi*) exit 0;; *) echo 'BLOCKED: Use pixi run gdal, not gdal/ogr2ogr directly.' >&2; exit 2;; esac;; *) exit 0;; esac"
          }
        ]
      }
    ]
  }
}
