{
  "$schema": "https://json.schemastore.org/claude-code-settings.json",
  "permissions": {
    "allow": [
      "Bash(pixi *)",
      "Bash(pixi run *)",
      "Bash(cd *)",
      "Bash(git status)",
      "Bash(git diff *)",
      "Bash(git log *)",
      "Bash(git branch *)",
      "Bash(ls *)",
      "Bash(dir *)",
      "Bash(mkdir *)",
      "Bash(test *)",
      "Bash(echo *)",
      "Bash(command -v *)",
      "Bash(stat *)",
      "Bash(wc *)",
      "Read",
      "Write",
      "Edit",
      "Glob",
      "Grep",
      "WebFetch(domain:pixi.prefix.dev)",
      "WebFetch(domain:duckdb.org)",
      "WebFetch(domain:gdal.org)",
      "WebFetch(domain:geoparquet.org)"
    ],
    "deny": [
      "Bash(rm -rf *)",
      "Bash(rm -r *)",
      "Bash(pixi clean *)",
      "Bash(npm *)",
      "Read(**/.env)",
      "Read(**/.env.local)",
      "Read(**/.env.production)",
      "Read(**/.env.secret*)",
      "Bash(cat **/.env)",
      "Bash(cat **/.env.*)"
    ],
    "ask": [
      "Read(**/.env.dev)",
      "Read(.claude/skills/duckdb/references/*.sql)",
      "Grep(.claude/skills/duckdb/references/*.sql)",
      "Bash(curl *)",
      "Bash(s5cmd *)",
      "Bash(cp *)",
      "Bash(mv *)",
      "Bash(rm -f *)",
      "Bash(cat *)",
      "Bash(find *)",
      "Bash(grep *)"
    ]
  }
}
